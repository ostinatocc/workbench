# Needed only for model-backed commands like `run` and `resume`.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-5.4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
WORKBENCH_MODEL_TIMEOUT_SECONDS=45
WORKBENCH_MODEL_MAX_RETRIES=1
WORKBENCH_MAX_COMPLETION_TOKENS=8192

# Optional. If unset, Workbench probes 3101 then 3001 and binds to the first healthy Aionis runtime.
# AIONIS_BASE_URL=http://127.0.0.1:3101
AIONIS_TENANT_ID=default
AIONIS_ACTOR=aionis-workbench

WORKBENCH_REPO_ROOT=/absolute/path/to/repo
WORKBENCH_SYSTEM_PROMPT=You are a rigorous multi-agent software engineering orchestrator.
